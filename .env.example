# Environment Configuration Example
# Copy this file to .env and update values for your environment

# ========== ENVIRONMENT SELECTION ==========
# Options: local, staging, production
ENVIRONMENT=local

# ========== BASE URL CONFIGURATION ==========
# URL where tests will be executed
BASE_URL=http://localhost:3000

# ========== BROWSER CONFIGURATION ==========
# Browser type: chromium, firefox, webkit
BROWSER=chromium

# Headless mode (true for CI, false for local debugging)
HEADLESS=true

# Slow down actions (milliseconds, 0 to disable)
SLOWDOWN=0

# ========== LOGGING CONFIGURATION ==========
# Log level: error, warn, info, debug
LOG_LEVEL=info

# ========== SCREENSHOT & VIDEO CONFIGURATION ==========
# Capture screenshots on failure
SCREENSHOT_ON_FAILURE=true

# Record videos on failure (useful for CI)
VIDEO_RECORDING=false

# ========== EXECUTION CONFIGURATION ==========
# Maximum parallel workers (1-4 recommended)
# Local: 1, Staging: 2, Production: 4
MAX_WORKERS=4

# Test timeout in milliseconds
TEST_TIMEOUT=30000

# Expect timeout in milliseconds
EXPECT_TIMEOUT=5000

# ========== RETRY CONFIGURATION ==========
# Maximum retry attempts for failed tests
MAX_RETRIES=2

# Maximum retry attempts for assertions
MAX_ASSERTION_RETRIES=3

# ========== API CONFIGURATION ==========
# API base URL (if different from BASE_URL)
API_BASE_URL=http://localhost:3001

# Enable mock API responses (true for local testing)
MOCK_API_RESPONSES=true

# ========== FEATURE FLAGS ==========
# Enable/disable test features
ENABLE_ACCESSIBILITY_TESTS=true
ENABLE_PERFORMANCE_TESTS=false
ENABLE_SECURITY_TESTS=true

# ========== NOTIFICATION CONFIGURATION ==========
# Email for test failure notifications
NOTIFICATION_EMAIL=qa-team@example.com

# Slack webhook for notifications (optional)
SLACK_WEBHOOK_URL=

# ========== PROXY CONFIGURATION (Optional) ==========
# Proxy URL if required
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# ========== CI/CD CONFIGURATION ==========
# CI environment detection (set by CI pipeline)
CI=false

# Build number or ID from CI system
CI_BUILD_NUMBER=
CI_BUILD_URL=
CI_COMMIT_SHA=
CI_BRANCH=

# ========== DEBUGGING CONFIGURATION ==========
# Enable verbose logging
DEBUG=false

# Keep browser open after test failure (for debugging)
DEBUG_ON_FAILURE=false

# ========== DATABASE CONFIGURATION (if needed) ==========
# Database connection for test data setup
DB_HOST=localhost
DB_PORT=5432
DB_NAME=test_db
DB_USER=test_user
DB_PASSWORD=test_password
